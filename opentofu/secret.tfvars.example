# Copier ce fichier en secret.tfvars et renseigner les valeurs réelles.
# secret.tfvars ne doit JAMAIS être commité dans Git.

ssh_public_key               = "ssh-ed25519 AAAA...coller_le_contenu_de_id_ed25519.pub..."
proxmox_ssh_user             = "root"
proxmox_ssh_private_key_path = "~/.ssh/id_ed25519"



# Chaque collègue génère SA clé SSH sur SON laptop
ssh-keygen -t ed25519 -C "prenom@infra-workshop"

# Chaque collègue envoie SA clé vers Proxmox
ssh-copy-id root@192.168.10.3